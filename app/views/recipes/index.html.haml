- provide(:title, "Let's cook together")

.row.justify-content-center
  .col-md-8
    .center-text
      .title Recipedia
.row.mb-3
  .col-12
    .nav-buttons.stacked-on-sm
      = link_to categories_path, class: 'btn btn-warning' do
        %i.fa.fa-list
        Browse by categories
      = link_to choice_recipes_path, class: 'btn btn-danger' do
        %i.fa.fa-plus-circle
        Add a recipe
= turbo_stream_from "reviews"
.row
  .col-12
    - if params[:search].present?
      %h1 Search results for "#{params[:search]}"
    - else
      %h1 Latest Recipes
#recipes{ data: { controller: "infinite-scroll", "infinite-scroll-next-page-value": @recipes.next_page, "infinite-scroll-search-value": params[:search] } }
  .row{ data: { "infinite-scroll-target": "container" } }
    = render @recipes
  - if @recipes.empty? && params[:search].present?
    .row
      .col-12.text-center.py-5
        %p.text-muted
          No recipes found matching
          %strong= params[:search]
  #recipes-end.infinite-end.text-center.py-4{ data: { "infinite-scroll-target": "sentinel" } }
    .d-flex.align-items-center.justify-content-center
      .spinner-border.spinner-border-sm.me-2{ role: "status" }
      %span Loading more recipes...
