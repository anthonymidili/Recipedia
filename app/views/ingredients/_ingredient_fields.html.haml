.nested-fields
  .callout-on-small-only
    .row
      .col-lg-1.order-lg-2.mb-3
        .inline-large-icon
          %button{type: "button", "data-action": "ingredients#remove", class: 'red-text'}
            %i.fa.fa-trash
            %span.hide-on-large
              Remove
      .col-lg-11.order-lg-1
        .row
          .col-12.col-lg-1.mb-3
            .slide
              %i.fa.fa-arrows-alt-v.large
          .col-4.col-lg-4.mb-3
            = f.label :quantity, class: "form-label"
            = f.text_field :quantity, placeholder: '1 cup', class: 'autofocus-on-new form-control'
          .col-8.col-lg-7.mb-3
            = f.label :item, class: "form-label"
            = f.text_field :item, placeholder: 'all-purpose flour', class: "form-control"
  = f.hidden_field :ingredient_order, class: 'ingredientOrderField'
  = f.hidden_field :_destroy, value: '0'
