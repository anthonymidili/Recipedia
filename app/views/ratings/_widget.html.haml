= turbo_frame_tag "recipe_rating_widget" do
  .rating-widget{ data: { controller: "rating", current_score: rating_display_score(recipe, user_rating) } }
    .rating-stars
      - 5.times do |i|
        - if can_rate_recipe?(recipe)
          = form_tag "/recipes/#{recipe.user.slug}/#{recipe.slug}/ratings", method: :post, style: "display: inline;" do
            = hidden_field_tag :score, i + 1
            %button.star-button{ type: "submit", class: ((i + 1) <= rating_display_score(recipe, user_rating) ? 'active-star' : 'inactive-star'), data: { rating_target: "star", score: i + 1, action: "mouseenter->rating#hover mouseleave->rating#leave" } }
              ★
        - else
          %span.star-button{ class: ((i + 1) <= rating_display_score(recipe, user_rating) ? 'active-star' : 'inactive-star'), style: "cursor: default;" }
            ★

    .rating-info
      %div
        - if recipe.ratings_count > 0
          %strong= recipe.average_rating.to_f.round(1)
          %span.text-muted (#{pluralize(recipe.ratings_count, 'vote')})
        - else
          %span.text-muted No ratings yet
      - if user_rating
        %div
          %small.text-muted= "Your rating: #{user_rating.score} ★"
