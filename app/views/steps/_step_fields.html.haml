.nested-fields
  .callout-on-small-only
    .row
      .col-lg-1.order-lg-2.mb-3
        .inline-large-icon
          %button{type: "button", "data-action": "steps#remove", class: 'red-text'}
            %i.fa.fa-trash
            %span.hide-on-large
              Remove
      .col-lg-11.order-lg-1
        .row
          .col-12.col-lg-1.mb-3
            .slide
              %i.fa.fa-arrows-alt-v.large
          .col-3.col-lg-2.mb-3
            = f.label :step_order, class: "form-label"
            = f.number_field :step_order, class: 'stepOrderField form-control', readonly: true
          .col-9.col-lg-9.mb-3
            = f.label :description, class: "form-label"
            = f.rich_text_area :description, rows: 2, placeholder: 'Heat oven to 425°F',
            class: 'autofocus-on-new form-control'
  = f.hidden_field :_destroy, value: '0'
